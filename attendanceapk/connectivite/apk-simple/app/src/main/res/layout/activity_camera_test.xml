<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/gradient_background"
    android:padding="16dp">

    <!-- Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/camera_title"
        android:textSize="24sp"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:layout_gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- Main Camera Container -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/glassmorphism_card"
        android:padding="8dp"
        android:layout_marginBottom="16dp">

        <!-- Camera Preview -->
        <FrameLayout
            android:id="@+id/cameraFrame"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="8dp" />

        <!-- Status Overlay -->
        <TextView
            android:id="@+id/txt_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:text="@string/status_initializing"
            android:textSize="16sp"
            android:textColor="@color/white"
            android:background="@drawable/status_background"
            android:padding="8dp"
            android:layout_margin="16dp" />

        <!-- Camera Controls -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:orientation="horizontal"
            android:layout_margin="16dp">

            <!-- Switch Camera Button -->
            <ImageButton
                android:id="@+id/btn_switch"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginEnd="32dp"
                android:background="@drawable/btn_camera_background"
                android:src="@android:drawable/ic_popup_sync"
                android:contentDescription="@string/btn_switch"
                android:scaleType="centerInside"
                android:padding="16dp" />

            <!-- Capture Button -->
            <ImageButton
                android:id="@+id/btn_capture"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/btn_capture_background"
                android:src="@android:drawable/ic_menu_camera"
                android:contentDescription="@string/btn_capture"
                android:scaleType="centerInside"
                android:padding="16dp" />

        </LinearLayout>

    </FrameLayout>

    <!-- Footer Info -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Application native de test de caméra MorphoTablet"
        android:textSize="14sp"
        android:textColor="@color/purple_light"
        android:textAlignment="center" />

</LinearLayout>
