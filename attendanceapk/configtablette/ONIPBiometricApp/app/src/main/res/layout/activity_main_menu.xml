<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/gradient_background"
    android:padding="24dp">

    <!-- Header avec logo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="32dp">

        <ImageView
            android:id="@+id/logo_image"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_onip_logo"
            android:contentDescription="Logo ONIP"
            android:layout_marginEnd="16dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ONIP RH"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/onip_blue" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gestion des Employés"
                android:textSize="14sp"
                android:textColor="@color/text_secondary" />

        </LinearLayout>

    </LinearLayout>

    <!-- Message de bienvenue -->
    <TextView
        android:id="@+id/welcome_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Bienvenue dans le système\nde gestion des employés ONIP"
        android:textSize="18sp"
        android:textColor="@color/text_primary"
        android:gravity="center"
        android:layout_marginBottom="32dp"
        android:lineSpacingExtra="4dp" />

    <!-- Menu principal -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Bouton Ajouter Employé -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/white">

            <Button
                android:id="@+id/add_employee_button"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="Ajouter un Employé"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/button_primary"
                android:drawableStart="@drawable/ic_person_add"
                android:drawablePadding="12dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp" />

        </androidx.cardview.widget.CardView>

        <!-- Bouton Voir Employés -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/white">

            <Button
                android:id="@+id/view_employees_button"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="Voir les Employés"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/onip_blue"
                android:background="@drawable/button_secondary"
                android:drawableStart="@drawable/ic_people"
                android:drawablePadding="12dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp" />

        </androidx.cardview.widget.CardView>

        <!-- Bouton Paramètres -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/white">

            <Button
                android:id="@+id/settings_button"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="Paramètres"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:background="@drawable/button_outline"
                android:drawableStart="@drawable/ic_settings"
                android:drawablePadding="12dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp" />

        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- Bouton de déconnexion -->
    <Button
        android:id="@+id/logout_button"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Déconnexion"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:background="@drawable/button_outline"
        android:drawableStart="@drawable/ic_logout"
        android:drawablePadding="8dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp" />

</LinearLayout>