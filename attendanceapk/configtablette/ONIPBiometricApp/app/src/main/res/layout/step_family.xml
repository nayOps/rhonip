<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- État matrimonial -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="État matrimonial"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp" />

                <RadioGroup
                    android:id="@+id/radio_marital_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/radio_single"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Célibataire"
                        android:textColor="@color/text_primary" />

                    <RadioButton
                        android:id="@+id/radio_married"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Marié(e)"
                        android:textColor="@color/text_primary" />

                    <RadioButton
                        android:id="@+id/radio_divorced"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Divorcé(e)"
                        android:textColor="@color/text_primary" />

                    <RadioButton
                        android:id="@+id/radio_widowed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Veuf(ve)"
                        android:textColor="@color/text_primary" />

                </RadioGroup>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Informations du conjoint -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Informations du conjoint"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/edit_spouse_name"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="8dp"
                    android:hint="Nom du conjoint"
                    android:inputType="textPersonName"
                    android:background="@drawable/input_background"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp" />

                <EditText
                    android:id="@+id/edit_spouse_first_name"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="8dp"
                    android:hint="Prénom du conjoint"
                    android:inputType="textPersonName"
                    android:background="@drawable/input_background"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp" />

                <EditText
                    android:id="@+id/edit_spouse_birth_date"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Date de naissance du conjoint (JJ/MM/AAAA)"
                    android:inputType="date"
                    android:background="@drawable/input_background"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Nombre d'enfants -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nombre d'enfants"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/edit_children_count"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Nombre d'enfants"
                    android:inputType="number"
                    android:background="@drawable/input_background"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Informations des enfants -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Informations des enfants"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <Button
                        android:id="@+id/btn_add_child"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="+ Ajouter"
                        android:textSize="12sp"
                        android:textColor="@color/white"
                        android:background="@drawable/button_primary"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp" />

                </LinearLayout>

                <!-- Container pour la liste des enfants -->
                <LinearLayout
                    android:id="@+id/children_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Les enfants seront ajoutés dynamiquement ici -->

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>
