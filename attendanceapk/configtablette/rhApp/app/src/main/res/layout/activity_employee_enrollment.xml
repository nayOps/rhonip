<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/gradient_background"
    android:padding="16dp">

    <!-- Header avec progression -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="@color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Titre de l'étape -->
            <TextView
                android:id="@+id/step_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Identité"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/onip_blue"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <!-- Description de l'étape -->
            <TextView
                android:id="@+id/step_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Informations personnelles de l'employé"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

            <!-- Barre de progression -->
            <ProgressBar
                android:id="@+id/progress_bar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:progress="8"
                android:max="100"
                android:progressTint="@color/onip_blue"
                android:layout_marginBottom="8dp" />

            <!-- Texte de progression -->
            <TextView
                android:id="@+id/progress_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Étape 1 sur 12"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:gravity="center" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Container pour les étapes du formulaire -->
    <FrameLayout
        android:id="@+id/step_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="16dp">

        <!-- Le contenu sera chargé dynamiquement selon l'étape -->

    </FrameLayout>

    <!-- Boutons de navigation -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- Bouton Précédent -->
        <Button
            android:id="@+id/previous_button"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Précédent"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:background="@drawable/button_outline"
            android:drawableStart="@drawable/ic_arrow_back"
            android:drawablePadding="8dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

        <!-- Bouton Suivant -->
        <Button
            android:id="@+id/next_button"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Suivant"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="@drawable/button_primary"
            android:drawableEnd="@drawable/ic_arrow_forward"
            android:drawablePadding="8dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

        <!-- Bouton Sauvegarder (visible seulement à la dernière étape) -->
        <Button
            android:id="@+id/save_button"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:visibility="gone"
            android:text="Sauvegarder"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="@drawable/button_success"
            android:drawableStart="@drawable/ic_save"
            android:drawablePadding="8dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

    </LinearLayout>

    <!-- Bouton Annuler -->
    <Button
        android:id="@+id/cancel_button"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="8dp"
        android:text="Annuler"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:background="@drawable/button_outline"
        android:drawableStart="@drawable/ic_cancel"
        android:drawablePadding="6dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp" />

</LinearLayout>