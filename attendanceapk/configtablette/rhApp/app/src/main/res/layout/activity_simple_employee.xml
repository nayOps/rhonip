<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#f5f5f5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- En-tête -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enregistrement Employé"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#2c3e50"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- Formulaire -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#ffffff"
            android:padding="16dp"
            android:elevation="2dp">

            <!-- NIN -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="NIN (Numéro d'Identification National)"
                android:textSize="14sp"
                android:textColor="#34495e"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/edit_nin"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Entrez le NIN"
                android:background="@drawable/edit_text_background"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <!-- Prénom -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Prénom *"
                android:textSize="14sp"
                android:textColor="#34495e"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/edit_first_name"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Entrez le prénom"
                android:background="@drawable/edit_text_background"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <!-- Nom -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nom *"
                android:textSize="14sp"
                android:textColor="#34495e"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/edit_last_name"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Entrez le nom"
                android:background="@drawable/edit_text_background"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <!-- Nom du milieu -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nom du milieu"
                android:textSize="14sp"
                android:textColor="#34495e"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/edit_middle_name"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Entrez le nom du milieu"
                android:background="@drawable/edit_text_background"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <!-- Email -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Email *"
                android:textSize="14sp"
                android:textColor="#34495e"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/edit_email"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Entrez l'email"
                android:inputType="textEmailAddress"
                android:background="@drawable/edit_text_background"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <!-- Téléphone -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Numéro de téléphone *"
                android:textSize="14sp"
                android:textColor="#34495e"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/edit_phone"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Entrez le numéro de téléphone"
                android:inputType="phone"
                android:background="@drawable/edit_text_background"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <!-- Poste -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Poste"
                android:textSize="14sp"
                android:textColor="#34495e"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/edit_job_title"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Entrez le poste"
                android:background="@drawable/edit_text_background"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <!-- Département -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Département"
                android:textSize="14sp"
                android:textColor="#34495e"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/edit_department"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Entrez le département"
                android:background="@drawable/edit_text_background"
                android:padding="12dp"
                android:layout_marginBottom="24dp" />

        </LinearLayout>

        <!-- Boutons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <Button
                android:id="@+id/btn_cancel"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Annuler"
                android:textColor="#ffffff"
                android:background="@drawable/btn_secondary_background"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btn_save"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Enregistrer"
                android:textColor="#ffffff"
                android:background="@drawable/btn_primary_background"
                android:layout_marginStart="8dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
