<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="6dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Header avec numéro et bouton supprimer -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/txt_child_number"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Enfant 1"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/onip_blue" />

            <Button
                android:id="@+id/btn_remove_child"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:text="×"
                android:textSize="16sp"
                android:textColor="@color/error"
                android:background="@drawable/button_outline"
                android:padding="0dp" />

        </LinearLayout>

        <!-- Nom de l'enfant -->
        <EditText
            android:id="@+id/edit_child_name"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginBottom="6dp"
            android:hint="Nom de l'enfant"
            android:inputType="textPersonName"
            android:background="@drawable/input_background"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:textSize="12sp" />

        <!-- Prénom de l'enfant -->
        <EditText
            android:id="@+id/edit_child_first_name"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginBottom="6dp"
            android:hint="Prénom de l'enfant"
            android:inputType="textPersonName"
            android:background="@drawable/input_background"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:textSize="12sp" />

        <!-- Postnom de l'enfant -->
        <EditText
            android:id="@+id/edit_child_middle_name"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginBottom="6dp"
            android:hint="Postnom de l'enfant"
            android:inputType="textPersonName"
            android:background="@drawable/input_background"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:textSize="12sp" />

        <!-- Sexe de l'enfant -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sexe: "
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_gravity="center_vertical" />

            <RadioGroup
                android:id="@+id/radio_child_gender"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/radio_child_male"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="M"
                    android:textSize="12sp"
                    android:textColor="@color/text_primary" />

                <RadioButton
                    android:id="@+id/radio_child_female"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="F"
                    android:textSize="12sp"
                    android:textColor="@color/text_primary" />

            </RadioGroup>

        </LinearLayout>

        <!-- Date de naissance de l'enfant -->
        <EditText
            android:id="@+id/edit_child_birth_date"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:hint="Date de naissance (JJ/MM/AAAA)"
            android:inputType="date"
            android:background="@drawable/input_background"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:textSize="12sp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
