<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@color/white"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- En-tête avec logo ONIP -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ONIP RH"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/onip_blue" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enregistrement Employé"
                android:textSize="16sp"
                android:textColor="@color/text_secondary"
                android:layout_marginEnd="8dp" />

            <!-- Bouton Présence -->
            <Button
                android:id="@+id/btn_attendance"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/button_outline"
                android:drawableStart="@drawable/ic_fingerprint"
                android:drawablePadding="0dp"
                android:padding="8dp"
                android:contentDescription="Marquer Présence"
                android:layout_marginEnd="8dp" />

            <!-- Bouton Paramètres -->
            <Button
                android:id="@+id/btn_settings"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/button_outline"
                android:drawableStart="@drawable/ic_settings"
                android:drawablePadding="0dp"
                android:padding="8dp"
                android:contentDescription="Paramètres" />

        </LinearLayout>

        <!-- Titre de l'étape -->
        <TextView
            android:id="@+id/step_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Informations Personnelles"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <!-- Progression -->
        <TextView
            android:id="@+id/step_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Étape 1 sur 3"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- ÉTAPE 1 - INFORMATIONS PERSONNELLES -->
        <LinearLayout
            android:id="@+id/step1_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:elevation="4dp">

            <!-- NIN -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="NIN (Numéro d'Identification National)"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/edit_nin"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Entrez le NIN"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_tertiary"
                android:background="@drawable/input_field_background"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <!-- Prénom -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Prénom *"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/edit_first_name"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Entrez le prénom"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_tertiary"
                android:background="@drawable/input_field_background"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <!-- Nom -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nom *"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/edit_last_name"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Entrez le nom"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_tertiary"
                android:background="@drawable/input_field_background"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <!-- Nom du milieu -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nom du milieu"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/edit_middle_name"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Entrez le nom du milieu"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_tertiary"
                android:background="@drawable/input_field_background"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <!-- Email -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Email *"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/edit_email"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Entrez l'email"
                android:inputType="textEmailAddress"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_tertiary"
                android:background="@drawable/input_field_background"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <!-- Téléphone -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Téléphone"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/edit_phone"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Entrez le numéro de téléphone"
                android:inputType="phone"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_tertiary"
                android:background="@drawable/input_field_background"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <!-- Poste -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Poste"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/edit_job_title"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Entrez le poste"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_tertiary"
                android:background="@drawable/input_field_background"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <!-- Département -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Département"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/edit_department"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Entrez le département"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_tertiary"
                android:background="@drawable/input_field_background"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <!-- Salaire -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Salaire"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/edit_salary"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Entrez le salaire"
                android:inputType="numberDecimal"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_tertiary"
                android:background="@drawable/input_field_background"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <!-- Date d'embauche -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Date d'embauche"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/edit_hire_date"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Entrez la date d'embauche"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_tertiary"
                android:background="@drawable/input_field_background"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

        </LinearLayout>

        <!-- ÉTAPE 2 - CAPTURE PHOTO ICAO -->
        <LinearLayout
            android:id="@+id/step2_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:elevation="4dp"
            android:visibility="gone">

            <!-- Preview caméra -->
            <FrameLayout
                android:id="@+id/camera_preview"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:background="@color/background_dark"
                android:layout_marginBottom="16dp" />

            <!-- Photo capturée -->
            <ImageView
                android:id="@+id/img_photo_preview"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_gravity="center"
                android:background="@color/background_dark"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:layout_marginBottom="16dp" />

            <!-- Bouton capture -->
            <Button
                android:id="@+id/btn_capture_photo"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="📸 Capturer Photo ICAO"
                android:textColor="@color/text_primary"
                android:background="@drawable/btn_capture_background"
                android:layout_marginBottom="16dp" />

            <!-- Statut ICAO -->
            <TextView
                android:id="@+id/txt_icao_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Initialisation de la caméra..."
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:gravity="center"
                android:background="@drawable/status_background"
                android:padding="12dp"
                android:layout_marginBottom="8dp" />

            <!-- Score ICAO -->
            <TextView
                android:id="@+id/txt_icao_score"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Score ICAO: --%"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <!-- Barre de progression ICAO -->
            <ProgressBar
                android:id="@+id/progress_icao"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:max="100"
                android:progress="0"
                android:visibility="gone" />

        </LinearLayout>

        <!-- ÉTAPE 3 - CAPTURE EMPREINTES -->
        <LinearLayout
            android:id="@+id/step3_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:elevation="4dp"
            android:visibility="gone">

            <!-- Preview empreinte -->
            <ImageView
                android:id="@+id/img_fingerprint_preview"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_gravity="center"
                android:background="@drawable/fingerprint_placeholder"
                android:scaleType="centerInside"
                android:layout_marginBottom="16dp" />

            <!-- Bouton démarrer capture -->
            <Button
                android:id="@+id/btn_start_fingerprints"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="👆 Démarrer Capture Empreintes"
                android:textColor="@color/text_primary"
                android:background="@drawable/btn_capture_background"
                android:layout_marginBottom="16dp" />

            <!-- Statut empreintes -->
            <TextView
                android:id="@+id/txt_fingerprint_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Prêt à capturer les empreintes..."
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:gravity="center"
                android:background="@drawable/status_background"
                android:padding="12dp"
                android:layout_marginBottom="8dp" />

            <!-- Score empreintes -->
            <TextView
                android:id="@+id/txt_fingerprint_score"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Score Qualité: --%"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <!-- Barre de progression empreintes -->
            <ProgressBar
                android:id="@+id/progress_fingerprint"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:max="100"
                android:progress="0"
                android:visibility="gone" />

            <!-- Progression des doigts -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Progression des doigts:"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/fingers_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>

        <!-- Boutons de navigation -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <Button
                android:id="@+id/btn_previous"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="← Précédent"
                android:textColor="@color/text_primary"
                android:background="@drawable/button_secondary"
                android:layout_marginEnd="8dp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btn_next"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Suivant →"
                android:textColor="@color/text_primary"
                android:background="@drawable/button_primary"
                android:layout_marginStart="8dp" />

            <Button
                android:id="@+id/btn_save"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="💾 Enregistrer"
                android:textColor="@color/text_primary"
                android:background="@drawable/button_primary"
                android:layout_marginStart="8dp"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>