<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/gradient_background"
    android:padding="24dp"
    android:gravity="center">

    <!-- Logo ONIP -->
    <ImageView
        android:id="@+id/logo_image"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginBottom="32dp"
        android:src="@drawable/ic_onip_logo"
        android:contentDescription="Logo ONIP" />

    <!-- Titre principal -->
    <TextView
        android:id="@+id/title_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ONIP - Office National\nd'Identification de la Population"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/onip_blue"
        android:gravity="center"
        android:layout_marginBottom="16dp"
        android:lineSpacingExtra="4dp" />

    <!-- Description -->
    <TextView
        android:id="@+id/description_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Gestion des Ressources Humaines\nEnregistrement des Employés avec Biométrie"
        android:textSize="16sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:layout_marginBottom="48dp"
        android:lineSpacingExtra="2dp" />

    <!-- Card d'authentification -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center">

            <!-- Icône d'empreinte -->
            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_fingerprint"
                android:contentDescription="Empreinte digitale"
                android:layout_marginBottom="16dp"
                android:tint="@color/onip_blue" />

            <!-- Texte d'instruction -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Authentification Biométrique"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Placez votre doigt sur le capteur pour vous authentifier"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:layout_marginBottom="24dp" />

            <!-- Bouton d'authentification -->
            <Button
                android:id="@+id/authenticate_button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Authentification"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/button_primary"
                android:drawableStart="@drawable/ic_fingerprint"
                android:drawablePadding="8dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Statut -->
    <TextView
        android:id="@+id/status_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Appuyez sur 'Authentification' pour commencer"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:background="@drawable/status_background"
        android:padding="12dp" />

</LinearLayout>
