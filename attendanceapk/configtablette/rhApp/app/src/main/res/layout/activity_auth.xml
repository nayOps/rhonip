<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_primary">

    <!-- Barre Tricolore -->
    <View
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:background="@drawable/tricolor_bar_horizontal" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center">

        <!-- Header -->
        <TextView
            android:id="@+id/txt_auth_title"
            style="@style/Heading1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Connexion"
            android:textAlignment="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/BodySmall"
            android:text="Authentification par empreinte digitale"
            android:textAlignment="center"
            android:layout_marginBottom="48dp" />

        <!-- Glassmorphic Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/glassmorphic_card"
            android:padding="32dp"
            android:layout_marginBottom="32dp"
            android:gravity="center">

            <!-- Fingerprint Image -->
            <ImageView
                android:id="@+id/img_auth_fingerprint"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_gravity="center"
                android:layout_marginBottom="24dp"
                android:src="@android:drawable/ic_menu_myplaces"
                android:contentDescription="Empreinte digitale" />

            <!-- Status Text -->
            <TextView
                android:id="@+id/txt_auth_status"
                style="@style/Body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Chargement..."
                android:textAlignment="center"
                android:layout_marginBottom="24dp" />

            <!-- Progress Bar -->
            <ProgressBar
                android:id="@+id/progress_auth"
                style="@style/ProgressBarFlat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Connexion Button (Glassmorphic) -->
        <Button
            android:id="@+id/btn_capture_auth"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Connexion"
            android:textColor="@color/rdc_blue"
            android:textSize="18sp"
            android:textStyle="bold"
            android:background="@drawable/glassmorphic_button"
            android:layout_marginBottom="16dp" />

        <!-- Back Button -->
        <Button
            android:id="@+id/btn_back_auth"
            style="@style/ButtonOutline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Retour" />

    </LinearLayout>

</LinearLayout>
