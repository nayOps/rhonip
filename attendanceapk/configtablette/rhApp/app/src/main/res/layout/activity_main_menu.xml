<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_primary">

    <!-- Barre Tricolore -->
    <View
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:background="@drawable/tricolor_bar_horizontal" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginBottom="48dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/Heading2"
            android:text="Menu Principal"
            android:textAlignment="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/BodySmall"
            android:text="Système de Gestion RH"
            android:textAlignment="center" />

    </LinearLayout>

    <!-- Main Actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="16dp">

        <!-- Button: Marquer Présence (Glassmorphic) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/glassmorphic_card"
            android:padding="24dp"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/btn_mark_attendance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Marquer Présence"
                android:textColor="@color/rdc_blue"
                android:textSize="18sp"
                android:textStyle="bold"
                android:background="@drawable/glassmorphic_button" />

        </LinearLayout>

        <!-- Button: Enregistrer Employé (Glassmorphic) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/glassmorphic_card"
            android:padding="24dp">

            <Button
                android:id="@+id/btn_register_employee"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enregistrer Employé"
                android:textColor="@color/rdc_blue"
                android:textSize="18sp"
                android:textStyle="bold"
                android:background="@drawable/glassmorphic_button" />

        </LinearLayout>

    </LinearLayout>

    <!-- Footer Actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/btn_settings"
            style="@style/ButtonOutline"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Paramètres"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btn_about"
            style="@style/ButtonOutline"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="À propos"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    </LinearLayout>

</LinearLayout>
