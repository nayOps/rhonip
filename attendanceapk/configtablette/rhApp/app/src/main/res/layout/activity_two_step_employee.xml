<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#f5f5f5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- En-tête -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enregistrement Employé"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#2c3e50"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- Titre de l'étape -->
        <TextView
            android:id="@+id/step_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Informations Personnelles"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#34495e"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <!-- Progression -->
        <TextView
            android:id="@+id/step_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Étape 1 sur 2"
            android:textSize="14sp"
            android:textColor="#7f8c8d"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- ÉTAPE 1 - INFORMATIONS PERSONNELLES -->
        <LinearLayout
            android:id="@+id/step1_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#ffffff"
            android:padding="16dp"
            android:elevation="2dp">

            <!-- NIN -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="NIN (Numéro d'Identification National)"
                android:textSize="14sp"
                android:textColor="#34495e"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/edit_nin"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Entrez le NIN"
                android:background="@drawable/edit_text_background"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <!-- Prénom -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Prénom *"
                android:textSize="14sp"
                android:textColor="#34495e"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/edit_first_name"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Entrez le prénom"
                android:background="@drawable/edit_text_background"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <!-- Nom -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nom *"
                android:textSize="14sp"
                android:textColor="#34495e"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/edit_last_name"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Entrez le nom"
                android:background="@drawable/edit_text_background"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <!-- Nom du milieu -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nom du milieu"
                android:textSize="14sp"
                android:textColor="#34495e"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/edit_middle_name"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Entrez le nom du milieu"
                android:background="@drawable/edit_text_background"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <!-- Email -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Email *"
                android:textSize="14sp"
                android:textColor="#34495e"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/edit_email"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Entrez l'email"
                android:inputType="textEmailAddress"
                android:background="@drawable/edit_text_background"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <!-- Téléphone -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Numéro de téléphone *"
                android:textSize="14sp"
                android:textColor="#34495e"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/edit_phone"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Entrez le numéro de téléphone"
                android:inputType="phone"
                android:background="@drawable/edit_text_background"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <!-- Poste -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Poste"
                android:textSize="14sp"
                android:textColor="#34495e"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/edit_job_title"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Entrez le poste"
                android:background="@drawable/edit_text_background"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <!-- Département -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Département"
                android:textSize="14sp"
                android:textColor="#34495e"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/edit_department"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Entrez le département"
                android:background="@drawable/edit_text_background"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <!-- Salaire -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Salaire"
                android:textSize="14sp"
                android:textColor="#34495e"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/edit_salary"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Entrez le salaire"
                android:inputType="numberDecimal"
                android:background="@drawable/edit_text_background"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <!-- Date d'embauche -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Date d'embauche"
                android:textSize="14sp"
                android:textColor="#34495e"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/edit_hire_date"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Entrez la date d'embauche"
                android:inputType="date"
                android:background="@drawable/edit_text_background"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

        </LinearLayout>

        <!-- ÉTAPE 2 - CAPTURE BIOMÉTRIQUE -->
        <LinearLayout
            android:id="@+id/step2_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#ffffff"
            android:padding="16dp"
            android:elevation="2dp"
            android:visibility="gone">

            <!-- Capture Photo -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Capture de Photo"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#34495e"
                android:layout_marginBottom="16dp" />

            <ImageView
                android:id="@+id/img_photo_preview"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                android:background="#f8f9fa"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/btn_capture_photo"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="📸 Capturer la Photo"
                android:textColor="#ffffff"
                android:background="@drawable/btn_primary_background"
                android:layout_marginBottom="24dp" />

            <!-- Capture Empreintes -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Capture des Empreintes"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#34495e"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• 5 doigts main gauche (Pouce, Index, Majeur, Annulaire, Auriculaire)\n• 5 doigts main droite (Pouce, Index, Majeur, Annulaire, Auriculaire)\n• Total: 10 empreintes"
                android:textSize="14sp"
                android:textColor="#7f8c8d"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/txt_fingerprint_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⏳ En attente de capture"
                android:textSize="14sp"
                android:textColor="#f39c12"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/btn_capture_fingerprints"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="👆 Capturer les 10 Empreintes"
                android:textColor="#ffffff"
                android:background="@drawable/btn_primary_background"
                android:layout_marginBottom="16dp" />

        </LinearLayout>

        <!-- Boutons de navigation -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <Button
                android:id="@+id/btn_previous"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="← Précédent"
                android:textColor="#ffffff"
                android:background="@drawable/btn_secondary_background"
                android:layout_marginEnd="8dp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btn_next"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Suivant →"
                android:textColor="#ffffff"
                android:background="@drawable/btn_primary_background"
                android:layout_marginStart="8dp" />

            <Button
                android:id="@+id/btn_save"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="💾 Enregistrer"
                android:textColor="#ffffff"
                android:background="@drawable/btn_primary_background"
                android:layout_marginStart="8dp"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
