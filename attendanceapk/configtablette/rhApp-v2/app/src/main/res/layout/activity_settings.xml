<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_blue">

    <!-- Barre Tricolore -->
    <View
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:background="@drawable/tricolor_bar_horizontal" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp">

            <Button
                android:id="@+id/btn_back_settings"
                style="@style/ButtonOutline"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="←"
                android:textSize="20sp" />

            <TextView
                style="@style/Heading1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Paramètres"
                android:textAlignment="center"
                android:textColor="@color/white" />

            <View
                android:layout_width="48dp"
                android:layout_height="48dp" />

        </LinearLayout>

        <!-- Glassmorphic Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/glassmorphic_card"
            android:padding="24dp"
            android:layout_marginBottom="16dp">

            <TextView
                style="@style/Heading2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Configuration Backend"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="24dp" />

            <!-- IP Backend -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="IP du Backend"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/edit_backend_ip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:hint="102.68.62.85"
                android:inputType="text"
                android:background="@drawable/input_flat"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <!-- Port Backend -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Port du Backend"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/edit_backend_port"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:hint="8100"
                android:inputType="number"
                android:background="@drawable/input_flat"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <!-- Status -->
            <TextView
                android:id="@+id/txt_settings_status"
                style="@style/BodySmall"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Configuration actuelle"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="16dp" />

            <!-- Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <Button
                    android:id="@+id/btn_test_connection"
                    style="@style/ButtonOutline"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Tester"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/btn_save_settings"
                    style="@style/ButtonPrimary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Sauvegarder"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <Button
                android:id="@+id/btn_reset_settings"
                style="@style/ButtonOutline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Réinitialiser"
                android:layout_marginTop="8dp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>

