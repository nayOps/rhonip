<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_primary"
    android:gravity="center">

    <!-- Barre Tricolore -->
    <View
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:background="@drawable/tricolor_bar_horizontal" />

    <LinearLayout
        android:id="@+id/layout_loading_main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <!-- Logo/Icon Space (Glassmorphic) -->
        <View
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:background="@drawable/glassmorphic_card"
            android:layout_marginBottom="48dp" />

        <!-- App Title -->
        <TextView
            style="@style/Heading1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ONIP RH"
            android:textAlignment="center"
            android:textColor="@color/rdc_blue"
            android:layout_marginBottom="16dp" />

        <!-- Status Text -->
        <TextView
            android:id="@+id/txt_loading_status"
            style="@style/Body"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Initialisation..."
            android:textAlignment="center"
            android:layout_marginBottom="32dp"
            android:textColor="@color/text_primary" />

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/progress_loading"
            style="@style/ProgressBarFlat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="0"
            android:layout_marginHorizontal="32dp" />

        <!-- Configuration IP (cachée par défaut) -->
        <LinearLayout
            android:id="@+id/layout_config_ip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/glassmorphic_card"
            android:padding="24dp"
            android:layout_marginTop="32dp"
            android:layout_marginHorizontal="32dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Configuration Backend"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="16dp" />

            <EditText
                android:id="@+id/edit_backend_ip_loading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:hint="IP du backend (ex: 192.168.1.74)"
                android:inputType="text"
                android:background="@drawable/input_flat"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <EditText
                android:id="@+id/edit_backend_port_loading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:hint="Port (ex: 8082)"
                android:inputType="number"
                android:background="@drawable/input_flat"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/btn_retry_loading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Relancer le chargement"
                android:background="@drawable/button_primary_flat"
                android:textColor="@color/white"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>

