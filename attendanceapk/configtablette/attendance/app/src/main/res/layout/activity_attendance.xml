<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_blue">

    <View
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:background="@drawable/tricolor_bar_horizontal" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                style="@style/OnipScreenTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp"
                android:gravity="center"
                android:text="@string/attendance_title" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:background="@drawable/onip_card"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="32dp">

                    <LinearLayout
                        android:id="@+id/layout_matricule_section"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:gravity="center"
                            android:text="@string/attendance_enter_matricule"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp" />

                        <EditText
                            android:id="@+id/edit_matricule"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:background="@drawable/input_flat"
                            android:hint="@string/attendance_matricule_hint"
                            android:inputType="textCapCharacters"
                            android:maxLines="1"
                            android:minHeight="48dp"
                            android:padding="12dp" />

                        <Button
                            android:id="@+id/btn_validate_matricule"
                            style="@style/ButtonAccent"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/attendance_continue" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layout_fingerprint_section"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <ImageView
                            android:id="@+id/img_attendance_fingerprint"
                            android:layout_width="200dp"
                            android:layout_height="200dp"
                            android:layout_gravity="center"
                            android:layout_marginBottom="24dp"
                            android:contentDescription="@string/attendance_place_finger"
                            android:src="@drawable/ic_fingerprint" />

                        <ProgressBar
                            android:id="@+id/progress_attendance"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="8dp"
                            android:layout_marginBottom="16dp"
                            android:max="100"
                            android:progress="0"
                            android:progressDrawable="@drawable/progress_bar_flat"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/txt_attendance_status"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="@string/attendance_place_finger"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp" />

                    </LinearLayout>

                </LinearLayout>

                <Button
                    android:id="@+id/btn_capture_attendance"
                    style="@style/ButtonAccent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/capture"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_settings_attendance"
            style="@style/ButtonSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="top|end"
            android:layout_margin="12dp"
            android:contentDescription="@string/btn_settings" />

    </FrameLayout>

</LinearLayout>
