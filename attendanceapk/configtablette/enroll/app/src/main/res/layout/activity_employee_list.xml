<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_secondary">

    <View
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:background="@drawable/tricolor_bar_horizontal" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/onip_card"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                style="@style/OnipBrandTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enrôlement biométrique"
                android:textSize="22sp" />

            <TextView
                style="@style/OnipSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Choisir un agent" />

        </LinearLayout>

        <EditText
            android:id="@+id/edit_search_employee"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Rechercher nom ou matricule..."
            android:background="@drawable/input_flat"
            android:padding="12dp"
            android:layout_marginBottom="12dp" />

        <ListView
            android:id="@+id/list_employees"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@drawable/onip_card"
            android:padding="8dp"
            android:divider="@color/border_light"
            android:dividerHeight="1dp" />

        <Button
            android:id="@+id/btn_back_employee_list"
            style="@style/ButtonOutline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Retour" />

    </LinearLayout>

</LinearLayout>
