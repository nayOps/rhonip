<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_secondary">

    <View
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:background="@drawable/tricolor_bar_horizontal" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/txt_enroll_employee"
                style="@style/Heading2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/txt_enroll_progress"
                style="@style/BodySmall"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/txt_current_finger"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/onip_card"
                android:gravity="center"
                android:padding="14dp"
                android:text="Doigt à capturer"
                android:textColor="@color/onip_blue"
                android:textSize="18sp"
                android:textStyle="bold" />

            <com.onip.enroll.widgets.HandDiagramView
                android:id="@+id/hand_diagram"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/onip_card"
                android:padding="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/onip_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp">

                <ImageView
                    android:id="@+id/img_enroll_fingerprint"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:contentDescription="Aperçu empreinte"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_fingerprint"
                    android:tint="@color/onip_blue" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Qualité capture"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <ProgressBar
                        android:id="@+id/progress_capture_quality"
                        style="@style/ProgressBarFlat"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="100"
                        android:progress="0" />

                    <TextView
                        android:id="@+id/txt_enroll_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:minHeight="48dp"
                        android:text="Initialisation du capteur..."
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Progression enrôlement Morpho"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <ProgressBar
                android:id="@+id/progress_enroll"
                style="@style/ProgressBarFlat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:max="10"
                android:progress="0" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Grille : vert = enregistré · jaune = doigt actuel · gris = à faire"
                android:textColor="@color/text_tertiary"
                android:textSize="11sp" />

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@color/background_primary">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border_light"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btn_capture_finger"
            style="@style/ButtonPrimary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Capturer le doigt" />

        <Button
            android:id="@+id/btn_reinit_sensor"
            style="@style/ButtonSecondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Réinitialiser le capteur" />

        <Button
            android:id="@+id/btn_back_enroll"
            style="@style/ButtonOutline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Retour" />

    </LinearLayout>

</LinearLayout>
