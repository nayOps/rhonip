        <item name="colorPrimaryDark">@color/onip_blue_dark</item>
        <item name="colorAccent">@color/onip_yellow</item>
        <item name="android:statusBarColor">@color/onip_blue_dark</item>
        <item name="android:navigationBarColor">@color/onip_blue_dark</item>
        <item name="android:windowBackground">@color/background_secondary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
