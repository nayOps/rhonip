<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/gradient_background"
    android:padding="24dp"
    android:gravity="center">

    <!-- Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Test Lecteur d'Empreintes"
        android:textSize="28sp"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:layout_marginBottom="32dp" />

    <!-- Main Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/glassmorphism_card"
        android:padding="32dp"
        android:layout_marginBottom="24dp">

        <!-- Fingerprint Preview Image -->
        <ImageView
            android:id="@+id/img_fingerprint"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_gravity="center"
            android:background="@drawable/fingerprint_placeholder"
            android:scaleType="centerInside"
            android:layout_marginBottom="16dp" />
            
        <!-- Quality Progress Bar -->
        <ProgressBar
            android:id="@+id/progress_quality"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_marginBottom="16dp"
            android:max="100"
            android:progressTint="@color/purple"
            android:progressBackgroundTint="@color/purple_light" />

        <!-- Status Text -->
        <TextView
            android:id="@+id/txt_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Initialisation du capteur..."
            android:textSize="18sp"
            android:textColor="@color/white"
            android:textAlignment="center"
            android:layout_marginBottom="16dp" />

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_marginBottom="16dp"
            android:progressTint="@color/purple"
            android:visibility="gone" />

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btn_capture"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Capturer Empreinte"
                android:textSize="16sp"
                android:background="@drawable/btn_primary_background"
                android:textColor="@color/white"
                android:padding="16dp"
                android:layout_marginEnd="16dp"
                android:enabled="false" />

            <Button
                android:id="@+id/btn_verify"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vérifier"
                android:textSize="16sp"
                android:background="@drawable/btn_secondary_background"
                android:textColor="@color/white"
                android:padding="16dp"
                android:enabled="false" />

        </LinearLayout>

    </LinearLayout>

    <!-- Info -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Application native de test du lecteur d'empreintes MorphoSmart"
        android:textSize="14sp"
        android:textColor="@color/purple_light"
        android:textAlignment="center" />

</LinearLayout>
