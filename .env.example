# =====================================================
# Configuration unifiee ONIP (register + rh)
# Copier vers .env :  cp .env.example .env
# =====================================================

# --- Base de donnees partagee (register + rh) ---
POSTGRES_DB=onip_db
POSTGRES_USER=onip_user
POSTGRES_PASSWORD=onip_password_change_me
POSTGRES_PORT=5433

# --- Redis partage (bases logiques separees par index) ---
# register: 0=fgp_core, 1=enrollment, 2=extensions | rh: 3=celery
REDIS_PASSWORD=onip_redis_change_me
REDIS_PORT=6379

# --- Register / FGP (biométrie uniquement) ---
FGP_CORE_PORT=8000
ENROLLMENT_GATEWAY_PORT=8001
RH_SERVICE_URL=http://rh_server:8000
BIOMETRIC_SERVICE_PORT=8003
FINGERPRINT_SERVICE_PORT=8010
FGP_FRONTEND_PORT=3000
# Attention : avec le profil traefik actif, le port 80 est géré par Traefik
# (register via localhost / register.onip.gouv.local, RH via rh.onip.gouv.local).
# Sans traefik, réactiver les ports de fgp_nginx dans compose/register.yml si besoin.
FGP_NGINX_HTTP_PORT=80
FGP_NGINX_HTTPS_PORT=443
GUICHET_INTERNAL_API_KEY=fgp_guichet_internal_dev
FGP_SECRET_KEY=fgp_secret_key_2025_very_secure
FGP_ENROLLMENT_SECRET_KEY=fgp_enrollment_secret_2025
FGP_EXTENSIONS_SECRET_KEY=fgp_extensions_secret_2025
FGP_FINGERPRINT_SECRET_KEY=fgp_fingerprint_secret_2025
FGP_BIOMETRIC_SECRET_KEY=fgp_biometric_secret_2025

# --- RH / Payday ---
# Chemins absolus (slash initial) — obligatoire pour CSS/JS sur /employee/change/…
STATIC_URL=/static/
MEDIA_URL=/media/
WHITENOISE_USE_FINDERS=1
RH_SERVER_PORT=8100
RH_DEBUG=1
RH_SECRET_KEY=change-me-rh-secret
RH_PUBLIC_HOST=rh.onip.gouv.local
RH_ALLOWED_HOSTS=localhost,127.0.0.1,rh.onip.gouv.local,rh.onip.localhost,rh.onip.gouv.lan,rh_server,server,192.168.1.79,192.168.1.74,192.168.1.72,102.68.62.85
# 0 = autorise http://IP:8100 (tests VPS). 1 = redirection HTTPS (prod Traefik).
RH_SSL_REDIRECT=0
RH_CSRF_TRUSTED_ORIGINS=http://rh.onip.gouv.local,http://rh.onip.localhost,http://rh.onip.gouv.lan,http://localhost:8100,http://127.0.0.1:8100,http://192.168.1.72:8100

# Production VPS : voir .env.prod.example (rh.onip.gouv.cd)

# --- Guichet Docker local + RH VPS (optionnel) ---
# NEXT_PUBLIC_RH_API_URL=http://102.68.62.85:8100
# RH_INTERNAL_API_URL=http://102.68.62.85:8100
# RH_PROXY_DOCKER_DEFAULTS=0
# Voir compose/register.guichet-vps.env.example

# --- Traefik + DNS local (profil traefik) — acces agents sans config poste ---
TRAEFIK_HTTP_PORT=80
TRAEFIK_DASHBOARD_PORT=8088
# IP LAN du PC serveur (ipconfig) — utilisee dans compose/coredns/hosts
SERVER_LAN_IP=192.168.10.104
COREDNS_PORT=53

# --- Keycloak (RH) ---
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_REALM=master
KEYCLOAK_CLIENT_ID=payday
KEYCLOAK_CLIENT_SECRET_KEY=change-me
KEYCLOAK_CLIENT_ADMIN_ROLE=admin
KEYCLOAK_REALM_ADMIN_ROLE=admin
KEYCLOAK_BASE_PATH=
KEYCLOAK_EXEMPT_URIS=

# --- Infra optionnelle ---
PGADMIN_EMAIL=admin@onip.local
PGADMIN_PASSWORD=admin123
PGADMIN_PORT=5050

# --- Monitoring (profil monitoring) ---
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=admin123
