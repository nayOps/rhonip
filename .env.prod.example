# =====================================================
# Configuration PRODUCTION ONIP (VPS)
# Copier : cp .env.prod.example .env
# Générer secrets : ./deploy/env-gen.sh .env.prod.example .env
# =====================================================

# --- Base de données (isolée de cpnpr/Présidence) ---
POSTGRES_DB=onip_db
POSTGRES_USER=onip_user
POSTGRES_PASSWORD=__PASSWORD__
POSTGRES_PORT=5433

# --- Redis ---
REDIS_PASSWORD=__PASSWORD__
REDIS_PORT=6379

# --- Domaine public RH ---
RH_PUBLIC_HOST=rh.onip.gouv.cd
RH_ALLOWED_HOSTS=rh.onip.gouv.cd,onip_rh_server,server,localhost,127.0.0.1
RH_CSRF_TRUSTED_ORIGINS=https://rh.onip.gouv.cd
CORS_ORIGIN_WHITELIST=https://rh.onip.gouv.cd

# --- RH / Payday ---
RH_SERVER_PORT=8100
RH_DEBUG=0
RH_SECRET_KEY=__SECRET__
GUICHET_INTERNAL_API_KEY=__SECRET__

# --- Keycloak (interne en MVP — route publique optionnelle plus tard) ---
KEYCLOAK_PORT=8080
KEYCLOAK_BASE_URL=http://onip_keycloak:8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=__PASSWORD__
KEYCLOAK_REALM=master
KEYCLOAK_CLIENT_ID=payday
KEYCLOAK_CLIENT_SECRET_KEY=__SECRET__
KEYCLOAK_CLIENT_ADMIN_ROLE=admin
KEYCLOAK_REALM_ADMIN_ROLE=admin
KEYCLOAK_BASE_PATH=
KEYCLOAK_EXEMPT_URIS=
PASSWORD_RESET_REDIRECT_URL=https://rh.onip.gouv.cd/login/

# --- Register (désactivé en prod VPS initiale — profil rh uniquement) ---
FGP_CORE_PORT=8000
ENROLLMENT_GATEWAY_PORT=8001
FGP_FRONTEND_PORT=3000
FGP_SECRET_KEY=__SECRET__
FGP_ENROLLMENT_SECRET_KEY=__SECRET__
NEXT_PUBLIC_RH_API_URL=https://rh.onip.gouv.cd
SERVER_LAN_IP=102.68.62.85

# --- Infra optionnelle (profil infra) ---
PGADMIN_EMAIL=admin@onip.gouv.cd
PGADMIN_PASSWORD=__PASSWORD__
PGADMIN_PORT=5050

# --- Déploiement VPS ---
# Chemin Traefik cpnpr (route HTTPS)
CPNPR_TRAEFIK_DYNAMIC=/home/adn/cpnpr/docker/traefik/config/dynamic
