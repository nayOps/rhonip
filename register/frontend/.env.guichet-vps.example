# Guichet local (poste opérateur) → APIs sur le VPS distant
# Copié en .env.local par register\scripts\start-guichet-local-vps.cmd
# Éditez NEXT_PUBLIC_GUICHET_INTERNAL_API_KEY : même valeur que GUICHET_INTERNAL_API_KEY sur le VPS (.env)

NEXT_PUBLIC_RH_API_URL=http://102.68.62.85:8100
RH_INTERNAL_API_URL=http://102.68.62.85:8100
RH_PROXY_DOCKER_DEFAULTS=0

NEXT_PUBLIC_API_URL=http://102.68.62.85:8201
NEXT_PUBLIC_FGP_CORE_URL=http://102.68.62.85:8200
NEXT_PUBLIC_FINGERPRINT_URL=http://102.68.62.85:8210

NEXT_PUBLIC_DEVICE_BRIDGE_URL=http://127.0.0.1:8765
NEXT_PUBLIC_USE_DEVICE_BRIDGE_DIRECT=true
NEXT_PUBLIC_ICAO_FACE_SERVICE_URL=http://127.0.0.1:50270

# Remplacer par la clé du VPS : ssh adn@102.68.62.85 "grep GUICHET_INTERNAL_API_KEY ~/rhonip/.env"
NEXT_PUBLIC_GUICHET_INTERNAL_API_KEY=fgp_guichet_internal_dev
