# =====================================================
# Configuration FGP - Fichier Général de la Population
# =====================================================

# Mode de fonctionnement
DEBUG=0
ENVIRONMENT=production

# Clés secrètes (CHANGEZ EN PRODUCTION!)
SECRET_KEY=fgp_secret_key_2025_very_secure_change_in_production
JWT_SECRET_KEY=jwt_secret_key_2025_change_in_production

# Base de données PostgreSQL
DATABASE_URL=postgresql://fgp_user:fgp_password_2025@postgres:5432/fgp_db
DB_HOST=postgres
DB_PORT=5432
DB_NAME=fgp_db
DB_USER=fgp_user
DB_PASSWORD=fgp_password_2025

# Cache Redis
REDIS_URL=redis://:fgp_redis_2025@redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=fgp_redis_2025

# URLs des services internes
FGP_CORE_URL=http://fgp_core:8000
ENROLLMENT_GATEWAY_URL=http://enrollment_gateway:8000
EXTENSIONS_SERVICE_URL=http://extensions_service:8000
ABIS_SERVICE_URL=http://abis_service:8000

# URLs publiques (pour le frontend)
NEXT_PUBLIC_API_URL=http://localhost:8001
NEXT_PUBLIC_FGP_CORE_URL=http://localhost:8000
NEXT_PUBLIC_EXTENSIONS_URL=http://localhost:8002
NEXT_PUBLIC_ABIS_URL=http://localhost:8003
NEXT_PUBLIC_FINGERPRINT_URL=http://localhost:8010
NEXT_PUBLIC_DEVICE_BRIDGE_URL=http://127.0.0.1:8765
NEXT_PUBLIC_USE_DEVICE_BRIDGE_DIRECT=true

# Device Bridge (poste guichet Windows — hors Docker)
DEVICE_BRIDGE_URL=http://127.0.0.1:8765
FINGERPRINT_SERVICE_URL=http://fingerprint_service:8010

# Sécurité
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com
CORS_ALLOW_CREDENTIALS=true

# JWT Configuration
JWT_ACCESS_TOKEN_LIFETIME=3600
JWT_REFRESH_TOKEN_LIFETIME=86400
JWT_ALGORITHM=HS256

# Configuration FGP
FGP_NIN_PREFIX=CD
FGP_NIN_YEAR=2025
FGP_NIN_SEQUENCE_START=1
FGP_BIOMETRIC_QUALITY_THRESHOLD=0.7
FGP_AUDIT_RETENTION_DAYS=2555
FGP_MAX_FILE_SIZE=10485760
FGP_ALLOWED_IMAGE_FORMATS=JPEG,PNG,JPG
FGP_ALLOWED_DOCUMENT_FORMATS=PDF,JPEG,PNG,JPG

# ABIS Configuration
ABIS_FACE_THRESHOLD=0.8
ABIS_FINGERPRINT_THRESHOLD=0.9
ABIS_IRIS_THRESHOLD=0.85
ABIS_MULTIMODAL_THRESHOLD=0.75

# Email Configuration (optionnel)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@fgp.rdc

# SMS Configuration (optionnel)
SMS_BACKEND=sms.backends.twilio.SmsBackend
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Monitoring
SENTRY_DSN=your-sentry-dsn-here
PROMETHEUS_RETENTION_TIME=200h
GRAFANA_ADMIN_PASSWORD=admin123

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# File Storage
MEDIA_ROOT=/app/media
STATIC_ROOT=/app/static
STATIC_URL=/static/
MEDIA_URL=/media/

# Celery Configuration
CELERY_BROKER_URL=redis://:fgp_redis_2025@redis:6379/1
CELERY_RESULT_BACKEND=redis://:fgp_redis_2025@redis:6379/2
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json
CELERY_TIMEZONE=Africa/Kinshasa

# Timezone
TIME_ZONE=Africa/Kinshasa
USE_TZ=true

# Language
LANGUAGE_CODE=fr-fr
USE_I18N=true
USE_L10N=true

# Session Configuration
SESSION_ENGINE=django.contrib.sessions.backends.cache
SESSION_CACHE_ALIAS=default
SESSION_COOKIE_AGE=3600
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Strict

# CSRF Configuration
CSRF_COOKIE_SECURE=true
CSRF_COOKIE_HTTPONLY=true
CSRF_COOKIE_SAMESITE=Strict

# Security Headers
SECURE_BROWSER_XSS_FILTER=true
SECURE_CONTENT_TYPE_NOSNIFF=true
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=true
SECURE_HSTS_PRELOAD=true
X_FRAME_OPTIONS=DENY

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=100

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=fgp-backups
BACKUP_S3_ACCESS_KEY=your-s3-access-key
BACKUP_S3_SECRET_KEY=your-s3-secret-key

# Integration URLs
CENI_API_URL=https://api.ceni.rdc
MENPS_API_URL=https://api.menps.rdc
HCR_API_URL=https://api.hcr.org
PNC_API_URL=https://api.pnc.rdc
FARDC_API_URL=https://api.fardc.rdc

# Guichet — parcours sans matériel (dev / domicile)
NEXT_PUBLIC_WORKFLOW_ALLOW_SKIP=true
NEXT_PUBLIC_FINGERPRINT_ALLOW_FAKE=true

# Development Settings
DEV_AUTO_RELOAD=true
DEV_DEBUG_TOOLBAR=false
DEV_EXTRA_LOGGING=false

# Production Settings
PROD_SSL_REDIRECT=true
PROD_COMPRESS_RESPONSES=true
PROD_CACHE_ENABLED=true
PROD_CDN_URL=https://cdn.fgp.rdc
